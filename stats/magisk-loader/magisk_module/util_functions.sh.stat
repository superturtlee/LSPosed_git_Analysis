[external][mlgmxyysd][mlgmxyysd@meowcat.org]check_magisk_version() {
[internal][vvb2060][vvb2060@gmail.com]  ui_print "- Magisk version: $MAGISK_VER_CODE"
[internal][howard20181][40033067+Howard20181@users.noreply.github.com]  if [ "$FLAVOR" == "riru" ] || [ "$FLAVOR" == "zygisk" ]; then
[internal][vvb2060][vvb2060@gmail.com]    if [ "$MAGISK_VER_CODE" -lt 24000 ]; then
[external][shana][shana@zju.edu.cn]      ui_print "*********************************************************"
[internal][vvb2060][vvb2060@gmail.com]      ui_print "! Please install Magisk v24+"
[external][shana][shana@zju.edu.cn]      abort    "*********************************************************"
[external][shana][shana@zju.edu.cn]    fi
[external][shana][shana@zju.edu.cn]  else
[external][wanghan1995315][wanghan1995315@gmail.com]    ui_print "*********************************************************"
[external][shana][shana@zju.edu.cn]    ui_print "! Unsupported flavor $FLAVOR"
[external][wanghan1995315][wanghan1995315@gmail.com]    abort    "*********************************************************"
[external][wanghan1995315][wanghan1995315@gmail.com]  fi
[external][mlgmxyysd][mlgmxyysd@meowcat.org]}
[external][mlgmxyysd][mlgmxyysd@meowcat.org]
[external][mlgmxyysd][mlgmxyysd@meowcat.org]require_new_android() {
[internal][vvb2060][vvb2060@gmail.com]  ui_print "*********************************************************"
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]  ui_print "! Unsupported Android version ${1} (below Oreo MR1)"
[internal][howard20181][40033067+Howard20181@users.noreply.github.com]  ui_print "! Learn more from our GitHub"
[internal][howard20181][40033067+Howard20181@users.noreply.github.com]  [ "$BOOTMODE" == "true" ] && am start -a android.intent.action.VIEW -d https://github.com/LSPosed/LSPosed/#supported-versions
[external][wanghan1995315][wanghan1995315@gmail.com]  abort    "*********************************************************"
[external][mlgmxyysd][mlgmxyysd@meowcat.org]}
