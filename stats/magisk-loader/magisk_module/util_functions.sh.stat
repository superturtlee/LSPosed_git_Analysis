[external][mlgmxyysd][mlgmxyysd@meowcat.org]check_android_version() {
[internal][vvb2060][vvb2060@gmail.com]  if [ "$API" -ge 27 ]; then
[internal][vvb2060][vvb2060@gmail.com]    ui_print "- Android SDK version: $API"
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]  else
[internal][vvb2060][vvb2060@gmail.com]    require_new_android "$API"
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]  fi
