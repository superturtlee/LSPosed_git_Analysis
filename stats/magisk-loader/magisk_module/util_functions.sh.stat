[external][wanghan1995315][wanghan1995315@gmail.com]
[external][wanghan1995315][wanghan1995315@gmail.com]check_incompatible_module() {
[external][wanghan1995315][wanghan1995315@gmail.com]  MODULEDIR="$(magisk --path)/.magisk/modules"
[internal][vvb2060][vvb2060@gmail.com]  for id in "riru_dreamland" "riru_edxposed" "riru_edxposed_sandhook" "taichi"; do
[external][416810799][416810799@qq.com]    if [ -d "$MODULEDIR/$id" ] && [ ! -f "$MODULEDIR/$id/disable" ] && [ ! -f "$MODULEDIR/$id/remove" ]; then
[internal][vvb2060][vvb2060@gmail.com]      ui_print "*********************************************************"
[internal][vvb2060][vvb2060@gmail.com]      ui_print "! Please disable or uninstall incompatible frameworks:"
[internal][vvb2060][vvb2060@gmail.com]      ui_print "! $id"
[internal][vvb2060][vvb2060@gmail.com]      abort    "*********************************************************"
[internal][vvb2060][vvb2060@gmail.com]      break
[internal][vvb2060][vvb2060@gmail.com]    fi
[external][wanghan1995315][wanghan1995315@gmail.com]  done
[external][wanghan1995315][wanghan1995315@gmail.com]}
