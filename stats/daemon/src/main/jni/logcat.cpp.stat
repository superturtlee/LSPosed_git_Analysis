[external][shana][shana@zju.edu.cn]            const auto *pi = __system_property_find(kLogdTagProp.data());
[external][shana][shana@zju.edu.cn]            uint32_t serial = 0;
[external][shana][shana@zju.edu.cn]            if (pi != nullptr) {
[external][shana][shana@zju.edu.cn]                __system_property_read_callback(pi, [](auto *c, auto, auto, auto s) {
