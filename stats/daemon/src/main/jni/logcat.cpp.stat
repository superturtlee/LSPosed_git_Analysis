[external][shana][shana@zju.edu.cn]                __builtin_mul_overflow(result, 1ULL << (10 * (suffix - suffixes)), &result)) {
[external][shana][shana@zju.edu.cn]                return -1;
[external][shana][shana@zju.edu.cn]            }
[external][shana][shana@zju.edu.cn]        }
[external][shana][shana@zju.edu.cn]        if (std::numeric_limits<size_t>::max() < result) {
