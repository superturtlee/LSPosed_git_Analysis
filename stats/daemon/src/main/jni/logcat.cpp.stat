[internal][vvb2060][vvb2060@gmail.com]            kLogdRestartWait <<= 1;
[internal][vvb2060][vvb2060@gmail.com]        } else {
[internal][vvb2060][vvb2060@gmail.com]            kLogdCrashCount = 0;
[internal][vvb2060][vvb2060@gmail.com]        }
[internal][vvb2060][vvb2060@gmail.com]    } else {
[external][shana][shana@zju.edu.cn]        Log("\nLogd maybe crashed (err="s + strerror(err) + "), retrying in 1s...\n");
[internal][vvb2060][vvb2060@gmail.com]    }
[internal][vvb2060][vvb2060@gmail.com]
[external][shana][shana@zju.edu.cn]    std::this_thread::sleep_for(1s);
[internal][vvb2060][vvb2060@gmail.com]}
