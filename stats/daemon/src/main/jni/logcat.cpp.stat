[external][shana][shana@zju.edu.cn]                   logd_crash_size != kErr &&
[external][shana][shana@zju.edu.cn]                   logd_crash_size >= kLogBufferSize))) {
[external][shana][shana@zju.edu.cn]                SetIntProp(kLogdSizeProp, std::max(kLogBufferSize, logd_size));
[external][shana][shana@zju.edu.cn]                SetIntProp(kLogdMainSizeProp, std::max(kLogBufferSize, logd_main_size));
[external][shana][shana@zju.edu.cn]                SetIntProp(kLogdCrashSizeProp, std::max(kLogBufferSize, logd_crash_size));
[external][shana][shana@zju.edu.cn]                SetStrProp(kLogdTagProp, "");
[external][shana][shana@zju.edu.cn]                SetStrProp("ctl.start", "logd-reinit");
