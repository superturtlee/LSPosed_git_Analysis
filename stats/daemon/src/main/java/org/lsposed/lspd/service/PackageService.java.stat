[external][shana][shana@zju.edu.cn]    private static Set<String> fetchProcesses(PackageInfo pkgInfo) {
[external][shana][shana@zju.edu.cn]        HashSet<String> processNames = new HashSet<>();
[external][shana][shana@zju.edu.cn]        if (pkgInfo == null) return processNames;
[external][shana][shana@zju.edu.cn]        for (ComponentInfo[] componentInfos : new ComponentInfo[][]{pkgInfo.activities, pkgInfo.receivers, pkgInfo.providers}) {
[external][shana][shana@zju.edu.cn]            if (componentInfos == null) continue;
[external][shana][shana@zju.edu.cn]            for (ComponentInfo componentInfo : componentInfos) {
[external][shana][shana@zju.edu.cn]                processNames.add(componentInfo.processName);
[external][shana][shana@zju.edu.cn]            }
[external][shana][shana@zju.edu.cn]        }
[external][shana][shana@zju.edu.cn]        if (pkgInfo.services == null) return processNames;
[external][shana][shana@zju.edu.cn]        for (ServiceInfo service : pkgInfo.services) {
[external][shana][shana@zju.edu.cn]            if ((service.flags & FLAG_ISOLATED_PROCESS) == 0) {
[external][shana][shana@zju.edu.cn]                processNames.add(service.processName);
[external][shana][shana@zju.edu.cn]            }
[external][shana][shana@zju.edu.cn]        }
[external][shana][shana@zju.edu.cn]        return processNames;
[external][shana][shana@zju.edu.cn]    }
