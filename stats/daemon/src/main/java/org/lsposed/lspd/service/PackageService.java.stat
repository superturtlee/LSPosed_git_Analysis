[external][shana][shana@zju.edu.cn]        if (pm == null) return new Pair<>(Collections.emptySet(), -1);
[external][shana][shana@zju.edu.cn]        PackageInfo pkgInfo = getPackageInfoWithComponents(app.packageName, MATCH_ALL_FLAGS, app.userId);
[external][shana][shana@zju.edu.cn]        if (pkgInfo == null || pkgInfo.applicationInfo == null)
[external][shana][shana@zju.edu.cn]            return new Pair<>(Collections.emptySet(), -1);
[external][shana][shana@zju.edu.cn]        return new Pair<>(fetchProcesses(pkgInfo), pkgInfo.applicationInfo.uid);
[external][shana][shana@zju.edu.cn]    }
