[external][tehcneko][7764726+tehcneko@users.noreply.github.com]    public static String getMD5Sum(String file) throws IOException {
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]        try {
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]            MessageDigest digest = MessageDigest.getInstance("MD5");
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]            InputStream is = new FileInputStream(file);
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]            byte[] buffer = new byte[8192];
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]            int read;
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]            while ((read = is.read(buffer)) > 0) {
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]                digest.update(buffer, 0, read);
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]            }
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]            is.close();
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]            byte[] md5sum = digest.digest();
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]            BigInteger bigInt = new BigInteger(1, md5sum);
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]            return bigInt.toString(16);
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]        } catch (NoSuchAlgorithmException e) {
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]            return "";
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]        }
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]    }
