[external][tehcneko][7764726+tehcneko@users.noreply.github.com]    static byte[] inputStreamToByteArray(InputStream is) throws IOException {
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]        ByteArrayOutputStream buf = new ByteArrayOutputStream();
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]        byte[] temp = new byte[1024];
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]        int read;
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]        while ((read = is.read(temp)) > 0) {
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]            buf.write(temp, 0, read);
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]        }
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]        is.close();
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]        return buf.toByteArray();
[external][tehcneko][7764726+tehcneko@users.noreply.github.com]    }
