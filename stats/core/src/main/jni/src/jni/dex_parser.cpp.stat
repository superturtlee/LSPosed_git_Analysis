[external][shana][shana@zju.edu.cn]    Value
[external][shana][shana@zju.edu.cn]    ParseValue(const dex::u1 **value, AnnotationList &annotation_list, ArrayList &array_list) {
[external][shana][shana@zju.edu.cn]        Value res;
[external][shana][shana@zju.edu.cn]        auto &[type, value_content] = res;
[external][shana][shana@zju.edu.cn]        auto header = *(*value)++;
[external][shana][shana@zju.edu.cn]        type = header & dex::kEncodedValueTypeMask;
[external][shana][shana@zju.edu.cn]        dex::u1 arg = header >> dex::kEncodedValueArgShift;
[external][shana][shana@zju.edu.cn]        switch (type) {
[external][shana][shana@zju.edu.cn]            case dex::kEncodedByte:
[external][shana][shana@zju.edu.cn]                value_content = ParseIntValue<int8_t>(value, arg + 1);
[external][shana][shana@zju.edu.cn]                break;
[external][shana][shana@zju.edu.cn]            case dex::kEncodedShort:
[external][shana][shana@zju.edu.cn]                value_content = ParseIntValue<int16_t>(value, arg + 1);
[external][shana][shana@zju.edu.cn]                break;
[external][shana][shana@zju.edu.cn]            case dex::kEncodedChar:
[external][shana][shana@zju.edu.cn]                value_content = ParseIntValue<uint16_t>(value, arg + 1);
[external][shana][shana@zju.edu.cn]                break;
[external][shana][shana@zju.edu.cn]            case dex::kEncodedInt:
[external][shana][shana@zju.edu.cn]                value_content = ParseIntValue<int32_t>(value, arg + 1);
[external][shana][shana@zju.edu.cn]                break;
[external][shana][shana@zju.edu.cn]            case dex::kEncodedLong:
[external][shana][shana@zju.edu.cn]                value_content = ParseIntValue<int64_t>(value, arg + 1);
[external][shana][shana@zju.edu.cn]                break;
[external][shana][shana@zju.edu.cn]            case dex::kEncodedFloat:
[external][shana][shana@zju.edu.cn]                value_content = ParseFloatValue<float>(value, arg + 1);
[external][shana][shana@zju.edu.cn]                break;
[external][shana][shana@zju.edu.cn]            case dex::kEncodedDouble:
[external][shana][shana@zju.edu.cn]                value_content = ParseFloatValue<double>(value, arg + 1);
[external][shana][shana@zju.edu.cn]                break;
[external][shana][shana@zju.edu.cn]            case dex::kEncodedMethodType:
[external][shana][shana@zju.edu.cn]            case dex::kEncodedMethodHandle:
[external][shana][shana@zju.edu.cn]            case dex::kEncodedString:
[external][shana][shana@zju.edu.cn]            case dex::kEncodedType:
[external][shana][shana@zju.edu.cn]            case dex::kEncodedField:
[external][shana][shana@zju.edu.cn]            case dex::kEncodedMethod:
[external][shana][shana@zju.edu.cn]            case dex::kEncodedEnum:
[external][shana][shana@zju.edu.cn]                value_content = ParseIntValue<uint32_t>(value, arg + 1);
[external][shana][shana@zju.edu.cn]                break;
[external][shana][shana@zju.edu.cn]            case dex::kEncodedArray:
[external][shana][shana@zju.edu.cn]                value_content.resize(sizeof(jint));
[external][shana][shana@zju.edu.cn]                *reinterpret_cast<jint *>(value_content.data()) = static_cast<jint>(array_list.size());
[external][shana][shana@zju.edu.cn]                array_list.emplace_back(ParseArray(value, annotation_list, array_list));
[external][shana][shana@zju.edu.cn]                break;
[external][shana][shana@zju.edu.cn]            case dex::kEncodedAnnotation:
[external][shana][shana@zju.edu.cn]                value_content.resize(sizeof(jint));
[external][shana][shana@zju.edu.cn]                *reinterpret_cast<jint *>(value_content.data()) = static_cast<jint>(annotation_list.size());
[external][shana][shana@zju.edu.cn]                annotation_list.emplace_back(ParseAnnotation(value, annotation_list, array_list));
[external][shana][shana@zju.edu.cn]                break;
[external][shana][shana@zju.edu.cn]            case dex::kEncodedNull:
[external][shana][shana@zju.edu.cn]                break;
[external][shana][shana@zju.edu.cn]            case dex::kEncodedBoolean:
[external][shana][shana@zju.edu.cn]                value_content = {static_cast<jbyte>(arg == 1)};
[external][shana][shana@zju.edu.cn]                break;
[external][shana][shana@zju.edu.cn]            default:
[external][shana][shana@zju.edu.cn]                __builtin_unreachable();
[external][shana][shana@zju.edu.cn]        }
[external][shana][shana@zju.edu.cn]        return res;
[external][shana][shana@zju.edu.cn]    }
[external][shana][shana@zju.edu.cn]
[external][shana][shana@zju.edu.cn]    Annotation
[external][shana][shana@zju.edu.cn]    ParseAnnotation(const dex::u1 **annotation, AnnotationList &annotation_list,
[external][shana][shana@zju.edu.cn]                    ArrayList &array_list) {
[external][shana][shana@zju.edu.cn]        Annotation ret = {dex::kVisibilityEncoded,
[external][shana][shana@zju.edu.cn]                          dex::ReadULeb128(annotation),
[external][shana][shana@zju.edu.cn]                          ElementList{}};
[external][shana][shana@zju.edu.cn]        auto &[vis, type, element_list] = ret;
[external][shana][shana@zju.edu.cn]        auto size = dex::ReadULeb128(annotation);
[external][shana][shana@zju.edu.cn]        element_list.resize(size);
[external][shana][shana@zju.edu.cn]        for (size_t j = 0; j < size; ++j) {
[external][shana][shana@zju.edu.cn]            auto &[name, value] = element_list[j];
[external][shana][shana@zju.edu.cn]            name = static_cast<jint>(dex::ReadULeb128(annotation));
[external][shana][shana@zju.edu.cn]            value = ParseValue(annotation, annotation_list, array_list);
[external][shana][shana@zju.edu.cn]        }
[external][shana][shana@zju.edu.cn]        return ret;
[external][shana][shana@zju.edu.cn]    }
[external][shana][shana@zju.edu.cn]
[external][shana][shana@zju.edu.cn]    Array
[external][shana][shana@zju.edu.cn]    ParseArray(const dex::u1 **array, AnnotationList &annotation_list, ArrayList &array_list) {
[external][shana][shana@zju.edu.cn]        auto size = dex::ReadULeb128(array);
[external][shana][shana@zju.edu.cn]        Array ret;
[external][shana][shana@zju.edu.cn]        ret.reserve(size);
[external][shana][shana@zju.edu.cn]        for (size_t i = 0; i < size; ++i) {
[external][shana][shana@zju.edu.cn]            ret.emplace_back(ParseValue(array, annotation_list, array_list));
[external][shana][shana@zju.edu.cn]        }
[external][shana][shana@zju.edu.cn]        return ret;
[external][shana][shana@zju.edu.cn]    }
