[external][shana][shana@zju.edu.cn]    template<class T>
[external][shana][shana@zju.edu.cn]    static std::vector<jbyte> ParseIntValue(const dex::u1 **pptr, size_t size) {
[external][shana][shana@zju.edu.cn]        static_assert(std::is_integral<T>::value, "must be an integral type");
[external][shana][shana@zju.edu.cn]        std::vector<jbyte> ret(sizeof(T));
[external][shana][shana@zju.edu.cn]        T &value = *reinterpret_cast<T *>(ret.data());
[external][shana][shana@zju.edu.cn]        for (size_t i = 0; i < size; ++i) {
[external][shana][shana@zju.edu.cn]            value |= T(*(*pptr)++) << (i * 8);
[external][shana][shana@zju.edu.cn]        }
[external][shana][shana@zju.edu.cn]
[external][shana][shana@zju.edu.cn]        // sign-extend?
[external][shana][shana@zju.edu.cn]        if constexpr (std::is_signed_v<T>) {
[external][shana][shana@zju.edu.cn]            size_t shift = (sizeof(T) - size) * 8;
[external][shana][shana@zju.edu.cn]            value = T(value << shift) >> shift;
[external][shana][shana@zju.edu.cn]        }
[external][shana][shana@zju.edu.cn]        return ret;
[external][shana][shana@zju.edu.cn]    }
[external][shana][shana@zju.edu.cn]
[external][shana][shana@zju.edu.cn]    template<class T>
[external][shana][shana@zju.edu.cn]    static std::vector<jbyte> ParseFloatValue(const dex::u1 **pptr, size_t size) {
[external][shana][shana@zju.edu.cn]        std::vector<jbyte> ret(sizeof(T));
[external][shana][shana@zju.edu.cn]        T &value = *reinterpret_cast<T *>(ret.data());
[external][shana][shana@zju.edu.cn]        int start_byte = sizeof(T) - size;
[external][shana][shana@zju.edu.cn]        for (dex::u1 *p = reinterpret_cast<dex::u1 *>(&value) + start_byte; size > 0;
[external][shana][shana@zju.edu.cn]             --size) {
[external][shana][shana@zju.edu.cn]            *p++ = *(*pptr)++;
[external][shana][shana@zju.edu.cn]        }
[external][shana][shana@zju.edu.cn]        return ret;
[external][shana][shana@zju.edu.cn]    }
