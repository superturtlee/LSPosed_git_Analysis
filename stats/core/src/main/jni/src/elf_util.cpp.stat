[external][shana][shana@zju.edu.cn]ElfW(Addr) ElfImg::GnuLookup(std::string_view name, uint32_t hash) const {
[external][shana][shana@zju.edu.cn]    static constexpr auto bloom_mask_bits = sizeof(ElfW(Addr)) * 8;
[external][shana][shana@zju.edu.cn]
[external][shana][shana@zju.edu.cn]    if (gnu_nbucket_ == 0 || gnu_bloom_size_ == 0) return 0;
[external][shana][shana@zju.edu.cn]
[external][shana][shana@zju.edu.cn]    auto bloom_word = gnu_bloom_filter_[(hash / bloom_mask_bits) % gnu_bloom_size_];
[external][shana][shana@zju.edu.cn]    uintptr_t mask = 0
[external][shana][shana@zju.edu.cn]                     | (uintptr_t) 1 << (hash % bloom_mask_bits)
[external][shana][shana@zju.edu.cn]                     | (uintptr_t) 1 << ((hash >> gnu_shift2_) % bloom_mask_bits);
[external][shana][shana@zju.edu.cn]    if ((mask & bloom_word) == mask) {
[external][shana][shana@zju.edu.cn]        auto sym_index = gnu_bucket_[hash % gnu_nbucket_];
[external][shana][shana@zju.edu.cn]        if (sym_index >= gnu_symndx_) {
[external][shana][shana@zju.edu.cn]            char *strings = (char *) strtab_start;
[external][shana][shana@zju.edu.cn]            do {
[external][shana][shana@zju.edu.cn]                auto *sym = dynsym_start + sym_index;
[external][shana][shana@zju.edu.cn]                if (((gnu_chain_[sym_index] ^ hash) >> 1) == 0
[external][shana][shana@zju.edu.cn]                    && name == strings + sym->st_name) {
[external][shana][shana@zju.edu.cn]                    return sym->st_value;
[external][shana][shana@zju.edu.cn]                }
[external][shana][shana@zju.edu.cn]            } while ((gnu_chain_[sym_index++] & 1) == 0);
[external][shana][shana@zju.edu.cn]        }
[external][shana][shana@zju.edu.cn]    }
[external][shana][shana@zju.edu.cn]    return 0;
[external][shana][shana@zju.edu.cn]}
