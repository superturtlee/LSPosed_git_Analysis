[external][shana][shana@zju.edu.cn]ElfW(Addr) ElfImg::ElfLookup(std::string_view name, uint32_t hash) const {
[external][shana][shana@zju.edu.cn]    if (nbucket_ == 0) return 0;
[external][shana][shana@zju.edu.cn]
[external][shana][shana@zju.edu.cn]    char *strings = (char *) strtab_start;
[external][shana][shana@zju.edu.cn]
[external][shana][shana@zju.edu.cn]    for (auto n = bucket_[hash % nbucket_]; n != 0; n = chain_[n]) {
[external][shana][shana@zju.edu.cn]        auto *sym = dynsym_start + n;
[external][shana][shana@zju.edu.cn]        if (name == strings + sym->st_name) {
[external][shana][shana@zju.edu.cn]            return sym->st_value;
[external][shana][shana@zju.edu.cn]        }
[external][shana][shana@zju.edu.cn]    }
[external][shana][shana@zju.edu.cn]    return 0;
[external][shana][shana@zju.edu.cn]}
