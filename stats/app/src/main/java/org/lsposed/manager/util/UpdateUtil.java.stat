[internal][vvb2060][vvb2060@gmail.com]                .apply();
[internal][vvb2060][vvb2060@gmail.com]        var updatedAt = Instant.parse(assets.get("updated_at").getAsString());
[internal][vvb2060][vvb2060@gmail.com]        var downloadUrl = assets.get("browser_download_url").getAsString();
[internal][vvb2060][vvb2060@gmail.com]        var zipTime = pref.getLong("zip_time", 0);
[internal][vvb2060][vvb2060@gmail.com]        if (!updatedAt.equals(Instant.ofEpochSecond(zipTime))) {
[internal][vvb2060][vvb2060@gmail.com]            var zip = downloadNewZipSync(downloadUrl, name);
[internal][vvb2060][vvb2060@gmail.com]            var size = assets.get("size").getAsLong();
[internal][vvb2060][vvb2060@gmail.com]            if (zip != null && zip.length() == size) {
