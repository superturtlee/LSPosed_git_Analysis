[internal][vvb2060][vvb2060@gmail.com]    private static void checkAssets(JsonObject assets, String releaseNotes, String api) {
[internal][vvb2060][vvb2060@gmail.com]        var pref = App.getPreferences();
[internal][vvb2060][vvb2060@gmail.com]        var name = assets.get("name").getAsString();
[internal][vvb2060][vvb2060@gmail.com]        var splitName = name.split("-");
