[internal][vvb2060][vvb2060@gmail.com]    private static File downloadNewZipSync(String url, String name) {
[internal][vvb2060][vvb2060@gmail.com]        var request = new Request.Builder().url(url).build();
[internal][vvb2060][vvb2060@gmail.com]        var zip = new File(App.getInstance().getCacheDir(), name);
