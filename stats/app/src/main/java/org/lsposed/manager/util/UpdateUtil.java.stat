[internal][vvb2060][vvb2060@gmail.com]                        .putLong("zip_time", updatedAt.getEpochSecond())
[internal][vvb2060][vvb2060@gmail.com]                        .putString("zip_file", zip.getAbsolutePath())
[internal][vvb2060][vvb2060@gmail.com]                        .apply();
[internal][vvb2060][vvb2060@gmail.com]            }
[internal][vvb2060][vvb2060@gmail.com]        }
