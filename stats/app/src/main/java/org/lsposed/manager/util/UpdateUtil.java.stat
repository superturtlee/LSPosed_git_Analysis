[internal][vvb2060][vvb2060@gmail.com]        var now = Instant.now();
[internal][vvb2060][vvb2060@gmail.com]        var buildTime = Instant.ofEpochSecond(BuildConfig.BUILD_TIME);
[internal][vvb2060][vvb2060@gmail.com]        var check = pref.getLong("latest_check", 0);
[internal][vvb2060][vvb2060@gmail.com]        if (check > 0) {
[internal][vvb2060][vvb2060@gmail.com]            var checkTime = Instant.ofEpochSecond(check);
[internal][vvb2060][vvb2060@gmail.com]            if (checkTime.atOffset(ZoneOffset.UTC).plusDays(30).toInstant().isBefore(now))
[internal][vvb2060][vvb2060@gmail.com]                return true;
[internal][vvb2060][vvb2060@gmail.com]            var code = pref.getInt("latest_version", 0);
[internal][vvb2060][vvb2060@gmail.com]            return code > BuildConfig.VERSION_CODE;
[internal][vvb2060][vvb2060@gmail.com]        }
[internal][vvb2060][vvb2060@gmail.com]        return buildTime.atOffset(ZoneOffset.UTC).plusDays(30).toInstant().isBefore(now);
